\algnewcommand{\LineComment}[1]{\State {\color{black!50!green}\smaller \(\triangleright\) \parbox[t]{\linewidth-\leftmargin-\widthof{\(\triangleright\) }}{\it #1}\smallskip}} % multi-line comment
