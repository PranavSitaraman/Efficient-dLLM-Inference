+def _aoae_format_replace_position(replace_position) -> str:
+    if replace_position is None:
+        return "None"
+    try:
+        return f"{int(replace_position[0])}:{int(replace_position[1])}"
+    except Exception:
+        return repr(replace_position)
+
+
+def _aoae_raise_if_nonfinite(
+    tensor: Optional[torch.Tensor],
+    *,
+    label: str,
+    layer_label: str,
+    replace_position=None,
+) -> None:
+    if tensor is None or torch.isfinite(tensor).all():
+        return
+    data = tensor.detach()
+    nan_count = int(torch.isnan(data).sum().item())
+    posinf_count = int(torch.isposinf(data).sum().item())
+    neginf_count = int(torch.isneginf(data).sum().item())
+    finite = data[torch.isfinite(data)]
+    if finite.numel() > 0:
+        finite_min = float(finite.min().item())
+        finite_max = float(finite.max().item())
+    else:
+        finite_min = float("nan")
+        finite_max = float("nan")
+    raise RuntimeError(
+        "[AOAE][NONFINITE_REPLACE_PATH] "
+        f"layer={layer_label} label={label} replace_position={_aoae_format_replace_position(replace_position)} "
+        f"nan={nan_count} +inf={posinf_count} -inf={neginf_count} "
+        f"finite_min={finite_min} finite_max={finite_max}. "
+        "This indicates an incoherent cached/stale KV state in the replace-position path."
+    )
+
